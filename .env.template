# Environment Variables Template
# Copy this file to .env and fill in your values
# Never commit .env file to version control!

# Groq API Configuration (Optional - System works without it)
GROQ_API_KEY=your_groq_api_key_here
TEXT_TO_SQL_USE_GROQ=false

# Model Configuration
GROQ_MODEL=llama-3.3-70b-versatile

# Logging Configuration
TEXT_TO_SQL_LOG_LEVEL=INFO

# System Limits
TEXT_TO_SQL_MAX_HISTORY=5
TEXT_TO_SQL_MAX_QUERY_LENGTH=1200
TEXT_TO_SQL_MAX_JOINS=2
